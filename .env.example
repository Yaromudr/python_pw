# Базовый URL тестируемого приложения (задать после получения тестового хоста)
BASE_URL=https://www.saucedemo.com/

# Движок браузера: chromium | firefox | webkit
BROWSER_ENGINE=chromium

# Канал chromium: chrome | msedge | "" (пусто = встроенный Chromium)
# По умолчанию используется реальный Chrome
BROWSER_CHANNEL=chrome

# true/false — запуск браузера в headless-режиме
HEADLESS=true

# Задержка между действиями Playwright, мс (полезно для отладки, 0 = выключено)
SLOW_MO=0

# Размер окна браузера
VIEWPORT_WIDTH=1920
VIEWPORT_HEIGHT=1080

# Таймаут ожидания элементов/действий по умолчанию, мс
DEFAULT_TIMEOUT=15000

# Логин и пароль
LOGIN=standard_user
PASSWORD=secret_sauce

# Товары для тестов корзины/заказа, через запятую (можно указать один или несколько)
PRODUCTS=Sauce Labs Backpack,Sauce Labs Bike Light